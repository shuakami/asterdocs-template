{
  "name": "asterdocs-template",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "docs:build": "tsx scripts/generate-docs.ts",
    "predev": "npm run docs:build",
    "prebuild": "npm run docs:build",
    "prelint": "npm run docs:build",
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "lint": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shuakami/asterdocs-template.git"
  },
  "homepage": "https://shuakami.github.io/asterdocs-template/",
  "keywords": [
    "docs",
    "markdown",
    "template",
    "vite",
    "react",
    "github-pages"
  ],
  "dependencies": {
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.546.0",
    "markdown-it": "^14.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
